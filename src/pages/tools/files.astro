---
export const toolMeta = {
	title: "文件",
	description: "下载公开文件资源",
	icon: "material-symbols:folder-open-rounded",
	order: 2,
};

import fs from "node:fs";
import path from "node:path";
import { siteConfig, tianyiApiConfig } from "@/config";
import FileExplorer from "@components/FileExplorer.svelte";
import OneDriveExplorer from "@components/OneDriveExplorer.svelte";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

interface FileItem {
	name: string;
	path: string;
	type: "file" | "directory";
	size?: number;
	mtime?: Date;
	children?: FileItem[];
}

function getFiles(dir: string, baseDir = ""): FileItem[] {
	const files = fs.readdirSync(dir);
	const result: FileItem[] = [];

	const exclude = [".DS_Store", "favicon", "icons", "js", "cdn", "aff"];

	for (const file of files) {
		if (exclude.includes(file)) continue;

		const filePath = path.join(dir, file);
		const stats = fs.statSync(filePath);
		const relativePath = path.join(baseDir, file).replace(/\\/g, "/");

		if (stats.isDirectory()) {
			result.push({
				name: file,
				path: relativePath,
				type: "directory",
				children: getFiles(filePath, relativePath),
			});
		} else {
			result.push({
				name: file,
				path: relativePath,
				type: "file",
				size: stats.size,
				mtime: stats.mtime,
			});
		}
	}

	return result.sort((a, b) => {
		if (a.type === b.type) {
			return a.name.localeCompare(b.name);
		}
		return a.type === "directory" ? -1 : 1;
	});
}

const filesDir = path.join(process.cwd(), "public", "files");
const fileTree = fs.existsSync(filesDir) ? getFiles(filesDir, "files") : [];

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{
			"@type": "ListItem",
			position: 1,
			name: "首页",
			item: Astro.site,
		},
		{
			"@type": "ListItem",
			position: 2,
			name: "文件",
			item: new URL("/files", Astro.site).toString(),
		},
	],
};
---

<MainGridLayout title="文件">
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
    <div class="card-base p-6 md:p-8 border border-gray-200 dark:border-white/10 rounded-xl">
        <div class="flex items-center justify-between gap-3 flex-wrap mb-6">
            <div class="flex items-center gap-2">
                <div class="h-8 w-8 rounded-lg flex items-center justify-center backdrop-blur-md border border-[var(--line-color)] bg-white/60 dark:bg-black/60">
                    <Icon name="material-symbols:folder-open" class="text-[1.5rem] text-[var(--primary)]" />
                </div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white">文件索引</h1>
            </div>
        </div>

        <div class="mb-4 text-gray-600 dark:text-white/50 text-sm flex flex-col gap-1">
            <p>这里展示了本站托管的各项公开资源，你可以点击查看并下载。</p>
            <p class="text-red-600 dark:text-red-400/80 text-xs italic">
                免责声明：本站不对任何文件的安全性做保证，请在下载或运行前自行核实，风险自担。
            </p>
        </div>

        <div class="flex gap-2 mb-6 border-b border-gray-200 dark:border-white/5 pb-1 overflow-x-auto no-scrollbar">
            <button 
                id="tab-local"
                class="tab-btn px-4 py-2 rounded-lg text-sm font-bold transition-all flex items-center gap-2 whitespace-nowrap active-tab"
            >
                <span class="h-7 w-7 rounded-lg flex items-center justify-center backdrop-blur-md border border-[var(--line-color)] bg-white/60 dark:bg-black/60">
                    <Icon name="material-symbols:home-storage-rounded" class="text-base text-[var(--primary)]" />
                </span>
                本站
            </button>
                        <button 
                id="tab-tianyi"
                class="tab-btn px-4 py-2 rounded-lg text-sm font-bold transition-all flex items-center gap-2 whitespace-nowrap text-gray-600 dark:text-white/50 hover:bg-gray-100 dark:hover:bg-white/5"
            >
                <span class="h-7 w-7 rounded-lg flex items-center justify-center backdrop-blur-md border border-[var(--line-color)] bg-white/60 dark:bg-black/60">
                    <Icon name="material-symbols:folder-open-rounded" class="text-base text-[var(--primary)]" />
                </span>
                天翼云
            </button>
            <button 
                id="tab-onedrive"
                class="tab-btn px-4 py-2 rounded-lg text-sm font-bold transition-all flex items-center gap-2 whitespace-nowrap text-gray-600 dark:text-white/50 hover:bg-gray-100 dark:hover:bg-white/5"
            >
                <span class="h-7 w-7 rounded-lg flex items-center justify-center backdrop-blur-md border border-[var(--line-color)] bg-white/60 dark:bg-black/60">
                    <Icon name="simple-icons:microsoftonedrive" class="text-base text-[var(--primary)]" />
                </span>
                                OneDrive
            </button>
        </div>
        <div id="content-local" class="tab-content">
            <FileExplorer client:visible items={fileTree} />
        </div>

                <div id="content-tianyi" class="tab-content hidden">
            <OneDriveExplorer client:only="svelte" apiBase={tianyiApiConfig.baseUrl} rootName="天翼云根目录" />
        </div>
        <div id="content-onedrive" class="tab-content hidden">
            <OneDriveExplorer client:only="svelte" />
        </div>


        <script is:inline>
                        function setupTabs() {
                const tabs = [
                    { tab: document.getElementById('tab-local'), content: document.getElementById('content-local') },
                    { tab: document.getElementById('tab-tianyi'), content: document.getElementById('content-tianyi') },
                    { tab: document.getElementById('tab-onedrive'), content: document.getElementById('content-onedrive') },
                ].filter(t => t.tab && t.content);

                if (tabs.length === 0) return;

                function activateTab(activeIndex) {
                    tabs.forEach((t, i) => {
                        if (i === activeIndex) {
                            t.tab.classList.add('active-tab');
                            t.tab.classList.remove('text-gray-600', 'dark:text-white/50', 'hover:bg-gray-100', 'dark:hover:bg-white/5');
                            t.content.classList.remove('hidden');
                        } else {
                            t.tab.classList.remove('active-tab');
                            t.tab.classList.add('text-gray-600', 'dark:text-white/50', 'hover:bg-gray-100', 'dark:hover:bg-white/5');
                            t.content.classList.add('hidden');
                        }
                    });
                }

                tabs.forEach((t, i) => {
                    t.tab.addEventListener('click', () => activateTab(i));
                });
            }


            setupTabs();
        </script>
    </div>
</MainGridLayout>

<style>
    .active-tab {
        @apply bg-[var(--primary)] text-black/70;
    }
    
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
